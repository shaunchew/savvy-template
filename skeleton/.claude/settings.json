{
  "permissions": {
    "deny": [
      "Bash(chmod -R 777:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard origin/*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf .claude:*)",
      "Bash(rm -rf .git:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(sudo:*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/credentials/**)",
      "Read(**/secrets/**)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/secret-scan.sh"
          }
        ]
      }
    ]
  }
}
